# envs/.envs.prod.template

# Template for Production Environment Variables for Radar-Core with Postgres and Metabase

# --- POSTGRES PRODUCTION SETTINGS ---
POSTGRES_USER=radar_admin
POSTGRES_PASSWORD=set_a_very_strong_password
POSTGRES_DB=postgres
# Custom variable for our 00-init-dbs.sh script
POSTGRES_MULTIPLE_DATABASES=radar,metabase
# Security: enforce SSL if necessary (cloud internal networks are usually safe, but good practice)
POSTGRES_SSL_MODE=prefer

# --- RADAR-CORE SETTINGS (Container connecting to sibling container) ---
# Connection using the internal Docker network service name
POSTGRES_HOST=db
POSTGRES_PORT=5432
# The app will connect to the 'radar' database created by initialization scripts
POSTGRES_DB_NAME=radar
# YML configuration file: create it in the same folder where is `settings.py` or set the absolute path to the file
# e.g. for Docker container: `settings.yml` if next to `settings.py`, or `/home/default/app/settings.yml`
RADAR_SETTING_FILE=settings.yml

# --- RADAR-CORE LOGGING SETTINGS ---
# Disable file logging for containerization environments
RADAR_ENABLE_FILE_LOGGING=false
# Log levels: 10.Debug, 20.Info, 30.Warning, 40.Error, 50.Critical
RADAR_LOG_LEVEL=30

# --- RADAR-CORE PERFORMANCE SETTINGS ---
# Number of parallel workers for the analyzer.
# Set to a positive integer (recommended), 0 or leave unset to use all available cores.
RADAR_MAX_WORKERS=2

# --- METABASE SETTINGS (Container connecting to sibling container) ---
# Metabase connects to the same 'db' service but to its own database
MB_DB_TYPE=postgres
MB_DB_HOST=db
MB_DB_PORT=5432
MB_DB_DBNAME=metabase
# Port to access Metabase UI from the browser (usually 80 or 443 via proxy)
METABASE_UI_PORT=80
