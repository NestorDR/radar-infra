# envs/envs.dev.template
# Template for Development Environment Variables for Postgres and Metabase on local Docker containers
#  and Radar-Core running on the host machine (Windows 11) or an external Docker container.

# --- POSTGRESQL CONTAINER SETTINGS ---
# These variables configure the DB container via 00-init-dbs.sh
POSTGRES_USER=postgres
POSTGRES_PASSWORD=set_your_dev_local_password
POSTGRES_DB=postgres
# Custom variable for 00-init-dbs.sh script
POSTGRES_MULTIPLE_DATABASES=radar,metabase
# Optional
POSTGRES_SSL_MODE=prefer
POSTGRES_OPTIONS='-c search_path%3Dpublic'
# Expose PostgreSQL on a different port to avoid conflicts with Windows's PostgreSQL host
POSTGRES_EXTERNAL_PORT=5433

# --- METABASE SETTINGS (Container connecting to sibling container) ---
# Metabase connects to the 'db' service but to its own database
MB_DB_TYPE=postgres
MB_DB_HOST=db
MB_DB_PORT=5432
MB_DB_DBNAME=metabase
# Port to access Metabase UI from browser
METABASE_UI_PORT=3000

# --- METABASE JAVA MEMORY LIMIT/TUNING for PERFORMANCE & STABILITY (HPC Optimization) ---
# Recommended for local development to keep things snappy
JAVA_OPTS=-Xmx1g